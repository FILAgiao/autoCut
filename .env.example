# 火山引擎 ASR (豆包语音识别大模型)
VOLC_APP_ID=your_app_id
VOLC_ACCESS_TOKEN=your_access_token
VOLC_SECRET_KEY=your_secret_key

# 火山引擎 TOS 对象存储（可选，有 TOS 时优先用 URL；否则自动 base64 直传音频）
TOS_BUCKET=
TOS_ENDPOINT=
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_REGION=cn-beijing

# LLM 服务 (OpenAI 兼容接口，推荐豆包 Seed/DeepSeek)
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_llm_api_key
LLM_MODEL=your_model_name

# 字幕默认样式
SUBTITLE_FONT=Source Han Sans SC
SUBTITLE_SIZE_RATIO=0.08
SUBTITLE_COLOR=1.0,1.0,1.0
SUBTITLE_STROKE_COLOR=0.0,0.0,0.0
SUBTITLE_STROKE_WIDTH=0.04
SUBTITLE_MAX_CHARS=12
SUBTITLE_POSITION_Y=-0.75

# 视频输出
OUTPUT_RESOLUTION=1080,1920

# 服务配置
HOST=127.0.0.1
PORT=8520
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_VIDEO_SIZE_MB=500
